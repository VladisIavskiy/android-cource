<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Слоган -->
    <TextView
        android:id="@+id/textViewBanana"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/tagline"
        android:textColor="#FFE135"
        android:layout_marginVertical="15dp"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Название товара (вверху слева) -->
    <TextView
        android:id="@+id/productName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/textViewBanana"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Картинка товара (слева под названием) -->
    <ImageView
        android:id="@+id/productMainImage"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginTop="16dp"
        android:adjustViewBounds="true"
        app:layout_constraintTop_toBottomOf="@id/productName"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Рейтинг -->
    <TextView
        android:id="@+id/rate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:textSize="16sp"
        app:drawableStartCompat="@drawable/black_star"
        app:drawableTint="#FFD700"
        app:layout_constraintTop_toTopOf="@id/productMainImage"
        app:layout_constraintStart_toEndOf="@id/productMainImage" />

    <!-- Старая цена -->
    <TextView
        android:id="@+id/oldPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/rate"
        app:layout_constraintStart_toStartOf="@id/rate" />

    <!-- Процент скидки (справа от старой цены) -->
    <TextView
        android:id="@+id/discount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/oval_background"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/oldPrice"
        app:layout_constraintTop_toTopOf="@id/oldPrice"
        app:layout_constraintBottom_toBottomOf="@id/oldPrice" />

    <!-- Реальная цена (под старой ценой) -->
    <TextView
        android:id="@+id/realPriceText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/oldPrice"
        app:layout_constraintStart_toStartOf="@id/rate" />

    <TextView
        android:id="@+id/cart"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/realPriceText"
        app:layout_constraintTop_toTopOf="@id/realPriceText"
        app:layout_constraintBottom_toBottomOf="@id/realPriceText"/>

    <Button
        android:id="@+id/buttonBuy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/button_outline"
        android:text="@string/buttonBuy"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toBottomOf="@id/realPriceText"
        app:layout_constraintStart_toStartOf="@id/rate"/>

    <!-- Описание товара — сразу под кнопкой (под priceLayout) -->
    <TextView
        android:id="@+id/productDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="start"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonBuy" />

    <!--  скролл картинок товара   -->
    <HorizontalScrollView
        android:id="@+id/horizontalScrollView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/productDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:scrollbars="none">
    <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/sliceBanana1"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_marginEnd="8dp"
                android:adjustViewBounds="true"
                android:src="@drawable/slidebanana1"/>

            <ImageView
                android:id="@+id/sliceBanana2"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_marginEnd="8dp"
                android:adjustViewBounds="true"
                android:src="@drawable/slidebanana2"/>

            <ImageView
                android:id="@+id/sliceBanana3"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:adjustViewBounds="true"
                android:src="@drawable/slidebanana3"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- todo Экран ошибки -->
    <LinearLayout
        android:id="@+id/errorLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/no_internet" />

        <TextView
            android:id="@+id/errorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Произошла ошибка сети" />

        <Button
            android:id="@+id/retryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Повторить" />
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>