<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Название товара (вверху слева) -->
    <TextView
        android:id="@+id/productName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Картинка товара (слева под названием) -->
    <ImageView
        android:id="@+id/productMainImage"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginTop="16dp"
        android:adjustViewBounds="true"
        app:layout_constraintTop_toBottomOf="@id/productName"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Рейтинг -->
    <TextView
        android:id="@+id/rate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:text="@string/rate"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="@id/productMainImage"
        app:layout_constraintStart_toEndOf="@id/productMainImage" />

    <!-- Скидончик -->
    <TextView
        android:id="@+id/crossedOutPriceText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/crossedOutPriceText"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/rate"
        app:layout_constraintStart_toStartOf="@id/rate" />

    <!-- Процент скидки (справа от старой цены) -->
    <TextView
        android:id="@+id/percent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/oval_background"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:text="-15%"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/crossedOutPriceText"
        app:layout_constraintTop_toTopOf="@id/crossedOutPriceText"
        app:layout_constraintBottom_toBottomOf="@id/crossedOutPriceText" />

    <!-- Реальная цена (под старой ценой) -->
    <TextView
        android:id="@+id/realPriceText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/realPriceText"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/crossedOutPriceText"
        app:layout_constraintStart_toStartOf="@id/rate" />

    <Button
        android:id="@+id/buttonBuy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/button_outline"
        android:text="@string/buttonBuy"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toBottomOf="@id/realPriceText"
        app:layout_constraintStart_toStartOf="@id/rate"/>

    <!-- Описание товара — сразу под кнопкой (под priceLayout) -->
    <TextView
        android:id="@+id/productDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="start"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonBuy" />

</androidx.constraintlayout.widget.ConstraintLayout>